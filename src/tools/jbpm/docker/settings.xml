<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              http://maven.apache.org/xsd/settings-1.0.0.xsd">
  <servers>
    <server>
      <id>business-central</id>
      <username>krisv</username>
      <password>krisv</password>
    </server>
  </servers>

  <profiles>
    <profile>
      <id>kie-server</id>
      <repositories>
        <repository>
          <id>business-central</id>
          <name>Business Central Maven Repository</name>
          <url>file:///opt/jboss/wildfly/bin/repositories/kie/global/</url>
          <layout>default</layout>
          <releases>
            <enabled>true</enabled>
            <updatePolicy>always</updatePolicy>
          </releases>
          <snapshots>
            <enabled>true</enabled>
            <updatePolicy>always</updatePolicy>
          </snapshots>
        </repository>
      </repositories>
    </profile>
  </profiles>

  <activeProfiles>
    <activeProfile>kie-server</activeProfile>
  </activeProfiles>
</settings>
