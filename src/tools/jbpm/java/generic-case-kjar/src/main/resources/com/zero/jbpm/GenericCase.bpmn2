<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:bpsim="http://www.bpsim.org/schemas/1.0" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:drools="http://www.jboss.org/drools" id="_z_flow_generic" targetNamespace="http://www.omg.org/bpmn20" exporter="jBPM Process Modeler" exporterVersion="2.0">
  <bpmn2:itemDefinition id="_CaseFileItem" structureRef="org.kie.api.runtime.conf.CaseFile"/>
  <bpmn2:process id="GenericCase" drools:packageName="com.zero.jbpm" drools:version="1.0" drools:adHoc="true" name="Generic Runtime Canvas" isExecutable="true" processType="Public">
    <bpmn2:extensionElements>
      <drools:metaData name="customDescription">
        <drools:metaValue><![CDATA[Generic Flow Renderer Instance]]></drools:metaValue>
      </drools:metaData>
    </bpmn2:extensionElements>
    <bpmn2:sequenceFlow id="_1" sourceRef="_start" targetRef="_end"/>
    <bpmn2:startEvent id="_start" name="Start">
      <bpmn2:outgoing>_1</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:endEvent id="_end" name="End">
      <bpmn2:incoming>_1</bpmn2:incoming>
      <bpmn2:terminateEventDefinition id="_terminate"/>
    </bpmn2:endEvent>
  </bpmn2:process>
  <bpmndi:BPMNDiagram id="_diagram">
    <bpmndi:BPMNPlane id="_plane" bpmnElement="GenericCase">
      <bpmndi:BPMNShape id="_start_shape" bpmnElement="_start">
        <dc:Bounds height="56.0" width="56.0" x="100.0" y="100.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="_end_shape" bpmnElement="_end">
        <dc:Bounds height="56.0" width="56.0" x="300.0" y="100.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="_1_edge" bpmnElement="_1">
        <di:waypoint x="156.0" y="128.0"/>
        <di:waypoint x="300.0" y="128.0"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn2:definitions>
