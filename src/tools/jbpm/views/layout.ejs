<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zero-BPM Console | <%= title %></title>
    <!-- Premium Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary: #1994ff;
            --primary-deep: #0b6dcf;
            --bg: #f4f6fb;
            --page-bg: #eef2f8;
            --panel: #ffffff;
            --panel-soft: #f8fafc;
            --sidebar-bg: #ffffff;
            --nav-panel: #ffffff;
            --card-bg: #ffffff;
            --text-main: #111827;
            --text-dim: #667085;
            --text-soft: #98a2b3;
            --accent: #1994ff;
            --success: #12b76a;
            --warning: #f79009;
            --danger: #f04438;
            --border: #dbe3ee;
            --border-strong: #c6d1df;
            --shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
        }

        body { 
            font-family: 'Inter', sans-serif; 
            background: var(--page-bg); 
            color: var(--text-main); 
            margin: 0; 
            display: flex; 
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
            font-size: 13px; /* Slightly smaller base */
        }

        /* Top Navbar Styling */
        .navbar {
            height: 64px;
            background: rgba(255, 255, 255, 0.94);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            z-index: 1000;
            backdrop-filter: blur(18px);
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        }

        .brand {
            font-size: 18px; /* Reduced */
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-main);
            text-decoration: none;
        }

        .brand-subtitle {
            font-weight: 500;
            font-size: 12px;
            color: var(--text-dim);
        }

        /* Hover Navigation System */
        .nav-menu {
            display: flex;
            align-items: center;
            gap: 8px;
            height: 100%;
        }

        .nav-dropdown {
            position: relative;
            height: 100%;
            display: flex;
            align-items: center;
        }

        .nav-dropdown.menu-root {
            position: static;
        }

        .nav-trigger {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0 16px;
            height: 42px;
            border-radius: 12px;
            color: #344054;
            text-decoration: none;
            font-weight: 700;
            font-size: 13px;
            transition: all 0.18s ease;
            cursor: pointer;
            border: 1px solid transparent;
        }

        .nav-dropdown:hover .nav-trigger {
            background: #f8fbff;
            color: var(--primary-deep);
            border-color: #d7e8fb;
        }

        .nav-dropdown:hover .dropdown-content {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .dropdown-content {
            position: absolute;
            top: calc(100% + 10px);
            left: 0;
            width: 1120px;
            background: rgba(255, 255, 255, 0.98);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 26px;
            display: block;
            box-shadow: 0 28px 80px rgba(15, 23, 42, 0.16);
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            backdrop-filter: blur(20px);
        }

        .nav-dropdown.menu-root .dropdown-content {
            left: 50%;
            right: auto;
            transform: translate(-50%, 10px);
            max-width: min(1120px, calc(100vw - 32px));
            width: min(1120px, calc(100vw - 32px));
        }

        .nav-dropdown.menu-root:hover .dropdown-content {
            transform: translate(-50%, 0);
        }

        .menu-dashboard {
            display: grid;
            grid-template-columns: 1.15fr 0.85fr;
            gap: 24px;
            align-items: start;
        }

        .menu-hero {
            background: linear-gradient(135deg, #f7fbff 0%, #eff6ff 100%);
            border: 1px solid #dbeafe;
            border-radius: 18px;
            padding: 22px;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.8);
        }

        .menu-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--primary-deep);
            background: rgba(25, 148, 255, 0.08);
            border: 1px solid rgba(25, 148, 255, 0.12);
            border-radius: 999px;
            padding: 7px 10px;
            margin-bottom: 14px;
        }

        .menu-hero h3 {
            margin: 0 0 10px 0;
            font-size: 24px;
            line-height: 1.15;
            letter-spacing: -0.03em;
            color: #0f172a;
        }

        .menu-hero p {
            margin: 0;
            color: #475467;
            line-height: 1.6;
            font-size: 13px;
            max-width: 560px;
        }

        .menu-hero-actions {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-top: 18px;
        }

        .menu-feature {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            text-decoration: none;
            border-radius: 16px;
            padding: 16px;
            background: white;
            border: 1px solid rgba(25, 148, 255, 0.12);
            box-shadow: 0 10px 24px rgba(25, 148, 255, 0.08);
            transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
        }

        .menu-feature:hover {
            transform: translateY(-1px);
            border-color: rgba(25, 148, 255, 0.25);
            box-shadow: 0 14px 30px rgba(25, 148, 255, 0.14);
        }

        .menu-feature-icon {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            background: linear-gradient(180deg, #f0f7ff, #dbeafe);
            color: var(--primary-deep);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .menu-feature-copy {
            min-width: 0;
        }

        .menu-feature-title {
            display: block;
            color: #0f172a;
            font-size: 14px;
            font-weight: 800;
            margin-bottom: 4px;
        }

        .menu-feature-text {
            color: #667085;
            font-size: 12px;
            line-height: 1.5;
        }

        .menu-side {
            display: grid;
            gap: 16px;
        }

        .menu-quickboard {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
        }

        .menu-tile {
            text-decoration: none;
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 16px;
            background: white;
            transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
        }

        .menu-tile:hover {
            border-color: #c7ddf8;
            box-shadow: 0 12px 26px rgba(15, 23, 42, 0.08);
            transform: translateY(-1px);
        }

        .menu-tile-icon {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            background: #f8fafc;
            color: var(--primary-deep);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 12px;
            font-size: 14px;
        }

        .menu-tile-title {
            display: block;
            color: #111827;
            font-size: 13px;
            font-weight: 800;
            margin-bottom: 4px;
        }

        .menu-tile-text {
            color: #667085;
            font-size: 11px;
            line-height: 1.5;
        }

        .menu-section-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
            margin-top: 22px;
            padding-top: 20px;
            border-top: 1px solid #eef2f7;
        }

        .dropdown-content.compact {
            width: 340px;
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .menu-section {
            min-width: 0;
        }

        .menu-section h4 {
            margin: 0 0 16px 0;
            color: #111827;
            font-size: 16px;
            font-weight: 800;
            padding-bottom: 14px;
            border-bottom: 1px solid #eef2f7;
        }

        .menu-list {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .menu-list.compact-links .dropdown-item {
            padding: 10px 10px;
            font-size: 12.5px;
        }

        .dropdown-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 12px;
            border-radius: 12px;
            color: #475467;
            text-decoration: none;
            font-size: 13px;
            font-weight: 700;
            transition: all 0.18s ease;
        }

        .dropdown-item:hover {
            color: #0b6dcf;
            background: #f5faff;
        }

        .dropdown-item i {
            width: 16px;
            text-align: center;
            color: #98a2b3;
        }

        .dropdown-item:hover i {
            color: #1994ff;
        }

        /* Main Content Container */
        .main-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background: var(--page-bg);
        }

        .page-header {
            padding: 16px 32px; /* Tightened */
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.72));
            backdrop-filter: blur(16px);
        }

        .content {
            flex: 1;
            padding: 32px; /* Tightened from 40px */
            overflow-y: auto;
        }

        /* Premium Card Components */
        .glass-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            box-shadow: var(--shadow);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .glass-card:hover {
            transform: translateY(-2px);
            border-color: var(--border-strong);
            box-shadow: 0 22px 44px rgba(15, 23, 42, 0.1);
        }

        .status-badge {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Tactical Modal System */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(12px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .modal-overlay.active { display: flex; opacity: 1; }

        .modal-content {
            background: white;
            border: 1px solid var(--border);
            border-radius: 16px;
            width: 100%;
            max-width: 680px;
            padding: 32px;
            box-shadow: 0 24px 64px rgba(15,23,42,0.24);
            transform: scale(0.95);
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .modal-overlay.active .modal-content { transform: scale(1); }

        .modal-header { margin-bottom: 24px; }
        .modal-header h2 { margin: 0; font-size: 20px; font-weight: 700; }
        .modal-header p { margin: 4px 0 0 0; color: var(--text-dim); font-size: 13px; }

        .form-group { margin-bottom: 20px; }
        .form-label { display: block; margin-bottom: 8px; font-size: 11px; font-weight: 700; color: var(--text-dim); text-transform: uppercase; }
        .form-input {
            width: 100%;
            background: white;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 12px;
            color: var(--text-main);
            font-family: inherit;
            box-sizing: border-box;
            transition: border-color 0.2s;
        }
        .form-input:focus { border-color: var(--primary); outline: none; }

        .action-btn {
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .action-btn:hover { opacity: 0.9; transform: translateY(-1px); }

        .menu-note {
            font-size: 11px;
            color: var(--text-dim);
            margin-top: 8px;
            line-height: 1.5;
        }

        .user-shell {
            display: flex;
            align-items: center;
            gap: 14px;
            padding-left: 16px;
            margin-left: 8px;
            border-left: 1px solid var(--border);
        }

        .user-meta {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 2px;
        }

        .user-name {
            font-size: 13px;
            font-weight: 800;
            color: var(--text-main);
        }

        .user-role {
            font-size: 10px;
            color: var(--primary-deep);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }

        .logout-link {
            text-decoration: none;
            color: #667085;
            font-size: 18px;
            transition: color 0.2s;
        }

        .logout-link:hover {
            color: var(--danger);
        }

        @media (max-width: 1220px) {
            .dropdown-content {
                width: 92vw;
                left: 50%;
                transform: translate(-50%, 10px);
            }

            .nav-dropdown:hover .dropdown-content {
                transform: translate(-50%, 0);
            }

            .nav-dropdown.menu-root .dropdown-content {
                left: 50%;
                transform: translate(-50%, 10px);
                width: min(92vw, calc(100vw - 24px));
                max-width: min(92vw, calc(100vw - 24px));
            }

            .nav-dropdown.menu-root:hover .dropdown-content {
                transform: translate(-50%, 0);
            }

            .menu-dashboard,
            .menu-section-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 900px) {
            .dropdown-content,
            .dropdown-content.compact {
                width: 94vw;
            }

            .nav-dropdown.menu-root .dropdown-content {
                width: min(94vw, calc(100vw - 20px));
                max-width: min(94vw, calc(100vw - 20px));
            }

            .menu-hero-actions,
            .menu-quickboard {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar">
        <a href="/" class="brand">
            <i class="fas fa-layer-group"></i>
            <span>Zero-BPM <span class="brand-subtitle">Business Console</span></span>
        </a>

        <div class="nav-menu">
            <div class="nav-dropdown menu-root">
                <a class="nav-trigger"><i class="fas fa-bars"></i> Menu <i class="fas fa-chevron-down" style="font-size: 10px; opacity: 0.5;"></i></a>
                <div class="dropdown-content">
                    <div class="menu-dashboard">
                        <div class="menu-hero">
                            <div class="menu-eyebrow"><i class="fas fa-sparkles"></i> Workflow Control</div>
                            <h3>Design flows, launch deployments, and operate runtime work from one control surface.</h3>
                            <p>Start where the intent is highest, then move into the supporting modules. The core paths stay prominent, while operational and reporting tools remain easy to reach.</p>

                            <div class="menu-hero-actions">
                                <a href="/projects" class="menu-feature">
                                    <span class="menu-feature-icon"><i class="fas fa-diagram-project"></i></span>
                                    <span class="menu-feature-copy">
                                        <span class="menu-feature-title">Build And Model</span>
                                        <span class="menu-feature-text">Open project spaces, iterate on BPMN designs, and shape process contracts.</span>
                                    </span>
                                </a>
                                <a href="/instances" class="menu-feature">
                                    <span class="menu-feature-icon"><i class="fas fa-wave-square"></i></span>
                                    <span class="menu-feature-copy">
                                        <span class="menu-feature-title">Run And Inspect</span>
                                        <span class="menu-feature-text">Launch new instances, follow execution, handle signals, and inspect runtime output.</span>
                                    </span>
                                </a>
                            </div>
                        </div>

                        <div class="menu-side">
                            <div class="menu-quickboard">
                                <a href="/deployments" class="menu-tile">
                                    <span class="menu-tile-icon"><i class="fas fa-server"></i></span>
                                    <span class="menu-tile-title">Deployment Hub</span>
                                    <span class="menu-tile-text">Manage versions, active deployments, and execution endpoints.</span>
                                </a>
                                <a href="/tasks" class="menu-tile">
                                    <span class="menu-tile-icon"><i class="fas fa-list-check"></i></span>
                                    <span class="menu-tile-title">Task Center</span>
                                    <span class="menu-tile-text">Claim, complete, and monitor work assigned across users and groups.</span>
                                </a>
                                <a href="/task-inbox" class="menu-tile">
                                    <span class="menu-tile-icon"><i class="fas fa-inbox"></i></span>
                                    <span class="menu-tile-title">Inbox</span>
                                    <span class="menu-tile-text">Focus on personal worklists and operational follow-up.</span>
                                </a>
                                <a href="<%= (user.role === 'admin' || user.permissions.includes('ANALYTICS_VIEW')) ? '/process-reports' : '/task-inbox' %>" class="menu-tile">
                                    <span class="menu-tile-icon"><i class="fas fa-chart-line"></i></span>
                                    <span class="menu-tile-title">Insights</span>
                                    <span class="menu-tile-text">Review process health, reporting, and execution trends.</span>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="menu-section-grid">
                        <div class="menu-section">
                            <h4>Studio</h4>
                            <div class="menu-list compact-links">
                                <a href="/projects" class="dropdown-item"><i class="fas fa-folder-tree"></i> Project Library</a>
                                <a href="/pages" class="dropdown-item"><i class="fas fa-file-lines"></i> Pages And App Surfaces</a>
                                <a href="/process-definitions" class="dropdown-item"><i class="fas fa-layer-group"></i> Process Definitions</a>
                            </div>
                        </div>
                        <div class="menu-section">
                            <h4>Operations</h4>
                            <div class="menu-list compact-links">
                                <a href="/deployments" class="dropdown-item"><i class="fas fa-rocket"></i> Provisioning And Releases</a>
                                <a href="/deployments" class="dropdown-item"><i class="fas fa-network-wired"></i> Execution Servers</a>
                                <a href="/instances" class="dropdown-item"><i class="fas fa-wave-square"></i> Process Instances</a>
                                <a href="/jobs" class="dropdown-item"><i class="fas fa-clock-rotate-left"></i> Jobs And Timers</a>
                            </div>
                        </div>
                        <div class="menu-section">
                            <h4>Assurance</h4>
                            <div class="menu-list compact-links">
                                <a href="/execution-errors" class="dropdown-item"><i class="fas fa-triangle-exclamation"></i> Execution Errors</a>
                                <% if (user.role === 'admin' || user.permissions.includes('ANALYTICS_VIEW')) { %>
                                    <a href="/process-reports" class="dropdown-item"><i class="fas fa-chart-column"></i> Process Reports</a>
                                    <a href="/task-reports" class="dropdown-item"><i class="fas fa-chart-bar"></i> Task Reports</a>
                                <% } else { %>
                                    <a href="/task-inbox" class="dropdown-item"><i class="fas fa-chart-column"></i> Process Reports</a>
                                    <a href="/task-inbox" class="dropdown-item"><i class="fas fa-chart-bar"></i> Task Reports</a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="nav-dropdown">
                <a class="nav-trigger"><i class="fas fa-shield-alt"></i> Governance</a>
                <div class="dropdown-content compact">
                    <div class="menu-section">
                        <h4>Access</h4>
                        <div class="menu-list">
                            <% if (user.role === 'admin' || user.permissions.includes('IAM_ADMIN')) { %>
                                <a href="/users" class="dropdown-item"><i class="fas fa-users-cog"></i> Identity Management</a>
                                <a href="/users" class="dropdown-item"><i class="fas fa-grid-2"></i> Access Matrix</a>
                            <% } %>
                            <% if (user.role === 'admin' || user.permissions.includes('AUDIT_VIEW')) { %>
                                <a href="/analytics" class="dropdown-item"><i class="fas fa-shield-halved"></i> Security Logs</a>
                            <% } %>
                            <a href="/projects" class="dropdown-item"><i class="fas fa-gear"></i> Tool Settings</a>
                        </div>
                        <div class="menu-note">Additional governance suites will be added module by module.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="user-shell">
            <div class="user-meta">
                <span class="user-name"><%= user.full_name %></span>
                <span class="user-role">
                    <%= user.role %> | <%= (user.groups || []).join(', ') || 'Global' %>
                </span>
            </div>
            <a href="/logout" class="logout-link">
                <i class="fas fa-power-off"></i>
            </a>
        </div>
    </nav>

    <!-- Main Content Area -->
    <div class="main-container">
        <% if (title !== 'System Overview') { %>
            <div class="page-header">
                <h1 style="font-size: 22px; font-weight: 700; margin: 0; letter-spacing: -0.5px;"><%= title %></h1>
                <div id="header-actions"></div>
            </div>
        <% } %>

        <main class="content">
            <% if (locals.messages && messages.success) { %>
                <div style="background: rgba(34, 197, 94, 0.1); border: 1px solid var(--success); color: var(--success); padding: 16px; border-radius: 8px; margin-bottom: 24px;">
                    <i class="fas fa-circle-check"></i> <%= messages.success %>
                </div>
            <% } %>
            <%- body %>
        </main>
    </div>
    <!-- Shared Global Modal Frame -->
    <div id="global-modal" class="modal-overlay">
        <div class="modal-content">
            <div id="modal-body"></div>
        </div>
    </div>

    <script>
        const ZeroModal = {
            open: (html) => {
                const overlay = document.getElementById('global-modal');
                document.getElementById('modal-body').innerHTML = html;
                overlay.classList.add('active');
                if (typeof window.onZeroModalToggle === 'function') window.onZeroModalToggle(true);
            },
            close: () => {
                const overlay = document.getElementById('global-modal');
                overlay.classList.remove('active');
                setTimeout(() => {
                    if (!overlay.classList.contains('active')) {
                        document.getElementById('modal-body').innerHTML = '';
                    }
                }, 180);
                if (typeof window.onZeroModalToggle === 'function') window.onZeroModalToggle(false);
            }
        };

        // Close on backdrop click
        document.getElementById('global-modal').onclick = (e) => {
            if (e.target === document.getElementById('global-modal')) ZeroModal.close();
        };
    </script>
</body>
</html>
