<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-bottom: 40px;">
    <!-- Metric Card 1: Active Instances -->
    <div class="glass-card" style="padding: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <p style="color: var(--text-dim); font-size: 11px; font-weight: 800; text-transform: uppercase; margin: 0 0 8px 0;">Active Orchestrations</p>
                <h2 style="font-size: 32px; margin: 0; color: var(--accent);">Running</h2>
            </div>
            <i class="fas fa-microchip" style="font-size: 24px; color: var(--accent); opacity: 0.5;"></i>
        </div>
        <div style="margin-top: 20px; font-size: 14px; display: flex; align-items: center; gap: 8px;">
            <span style="color: var(--success); font-weight: 700;">+12%</span>
            <span style="color: var(--text-dim);">from last 24h</span>
        </div>
    </div>

    <!-- Metric Card 2: Pending Tasks -->
    <div class="glass-card" style="padding: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <p style="color: var(--text-dim); font-size: 11px; font-weight: 800; text-transform: uppercase; margin: 0 0 8px 0;">Human Worklist</p>
                <h2 style="font-size: 32px; margin: 0; color: #fbbf24;">Pending</h2>
            </div>
            <i class="fas fa-tasks" style="font-size: 24px; color: #fbbf24; opacity: 0.5;"></i>
        </div>
        <div style="margin-top: 20px; font-size: 14px; display: flex; align-items: center; gap: 8px;">
            <span style="color: #fbbf24; font-weight: 700;">18 Tasks</span>
            <span style="color: var(--text-dim);">awaiting claim</span>
        </div>
    </div>

    <!-- Metric Card 3: System Users -->
    <div class="glass-card" style="padding: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <p style="color: var(--text-dim); font-size: 11px; font-weight: 800; text-transform: uppercase; margin: 0 0 8px 0;">Organization</p>
                <h2 style="font-size: 32px; margin: 0; color: var(--primary);">Managed</h2>
            </div>
            <i class="fas fa-users-cog" style="font-size: 24px; color: var(--primary); opacity: 0.5;"></i>
        </div>
        <div style="margin-top: 20px; font-size: 14px; display: flex; align-items: center; gap: 8px;">
            <span style="color: var(--primary); font-weight: 700;">5 Depts</span>
            <span style="color: var(--text-dim);">active in IAM</span>
        </div>
    </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 13fr; gap: 24px;">
    <!-- Left: Welcome / Quick Start -->
    <div style="display: flex; flex-direction: column; gap: 24px; grid-column: span 2;">
        <div class="glass-card" style="position: relative; overflow: hidden; background: linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(15, 23, 42, 0) 100%);">
            <div style="position: absolute; right: -20px; bottom: -20px; font-size: 180px; color: var(--primary); opacity: 0.05;">
                <i class="fas fa-rocket"></i>
            </div>
            <h1 style="font-size: 28px; margin: 0 0 12px 0;">Welcome to Zero-BPM V4</h1>
            <p style="color: var(--text-dim); font-size: 16px; max-width: 600px; line-height: 1.6;">
                The next-generation business process suite is now fully orchestrated. From visual modeling with dynamic expression binding to departmental task management, your entire operation is centralized in one visual audit console.
            </p>
            <div style="display: flex; gap: 16px; margin-top: 32px;">
                <a href="/modeler" class="action-btn" style="background: var(--primary); text-decoration: none;">Launch Modeler Studio</a>
                <a href="/instances" class="action-btn" style="background: transparent; border: 1px solid var(--border); text-decoration: none;">Monitor Active Processes</a>
            </div>
        </div>
    </div>
</div>
