<div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px;">
    <div>
        <h1 style="font-size: 28px; margin: 0 0 8px 0; font-weight: 800; letter-spacing: -1px;">Operational Worklist</h1>
        <p style="color: var(--text-dim); margin: 0; font-size: 14px;">Review and process tactical orchestration tasks across your organizational units.</p>
    </div>
    <% if (user && (user.role === 'admin' || user.role === 'manager')) { %>
        <div style="display: flex; gap: 8px; background: rgba(255,255,255,0.05); padding: 4px; border-radius: 12px; border: 1px solid var(--border);">
            <a href="/tasks?view=personal" class="tab-btn <%= viewType === 'PERSONAL' ? 'active' : '' %>" style="text-decoration: none;">Personal Workspace</a>
            <a href="/tasks?view=global" class="tab-btn <%= viewType === 'GLOBAL' ? 'active' : '' %>" style="text-decoration: none;">System-Wide Oversight</a>
        </div>
    <% } %>
</div>

<div class="glass-card" style="padding: 0; overflow: hidden;">
    <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
        <thead>
            <tr style="text-align: left; color: var(--text-dim); background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--border);">
                <th style="padding: 16px 24px;">Task ID & Priority</th>
                <th>Process Context</th>
                <th>Status</th>
                <th>Current Identity</th>
                <th style="text-align: right; padding-right: 24px;">Orchestration</th>
            </tr>
        </thead>
        <tbody>
            <% if (tasks && tasks.length > 0) { %>
                <% tasks.forEach(task => { %>
                    <tr style="border-bottom: 1px solid var(--border); transition: all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.015)'" onmouseout="this.style.background='transparent'">
                        <td style="padding: 20px 24px;">
                            <div style="display: flex; align-items: center; gap: 12px;">
                                <div style="display: flex; flex-direction: column; align-items: center; width: 32px;">
                                    <span style="font-size: 14px; font-weight: 800; color: white;"><%= task.id %></span>
                                    <% 
                                        let pColor = '#94a3b8';
                                        if (task.priority >= 4) pColor = '#ef4444'; 
                                        else if (task.priority >= 2) pColor = '#f59e0b';
                                    %>
                                    <div style="font-size: 8px; font-weight: 900; color: <%= pColor %>;">P<%= task.priority || 1 %></div>
                                </div>
                                <div style="width: 1px; height: 24px; background: var(--border);"></div>
                                <div style="font-weight: 600; color: white;"><%= task.node_id %></div>
                            </div>
                        </td>
                        <td>
                            <div style="font-size: 12px; color: var(--accent); font-weight: 700;"><%= task.workflow_name || 'System Process' %></div>
                            <div style="font-size: 10px; color: var(--text-dim); opacity: 0.6;">Instance: <%= task.instance_id.substring(0,8) %>...</div>
                        </td>
                        <td>
                            <% 
                                let sColor = 'var(--text-dim)';
                                if (task.status === 'READY') sColor = '#38bdf8';
                                if (task.status === 'RESERVED' || task.status === 'IN_PROGRESS') sColor = '#f59e0b';
                                if (task.status === 'COMPLETED') sColor = '#22c55e';
                            %>
                            <span class="status-badge" style="background: rgba(255,255,255,0.05); color: <%= sColor %>; border: 1px solid rgba(255,255,255,0.1);">
                                <%= task.status %>
                            </span>
                        </td>
                        <td>
                            <% if (task.assignee) { %>
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <div style="width: 20px; height: 20px; background: rgba(255,255,255,0.1); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 8px;">
                                        <%= task.assignee.substring(0,2).toUpperCase() %>
                                    </div>
                                    <span style="font-size: 12px; color: var(--text-dim);"><%= task.assignee %></span>
                                </div>
                            <% } else { %>
                                <span style="font-size: 11px; color: var(--text-dim); font-style: italic; opacity: 0.5;">Unassigned (Group Pool)</span>
                            <% } %>
                        </td>
                        <td style="text-align: right; padding-right: 24px;">
                            <div style="display: flex; gap: 8px; justify-content: flex-end;">
                                <% if (task.status === 'READY' || (task.status === 'RESERVED' && task.assignee !== user.username)) { %>
                                    <button onclick="claimTask('<%= task.id %>')" class="action-btn" style="background: var(--primary); font-size: 11px; padding: 6px 14px;">
                                        <i class="fas fa-check"></i> Claim
                                    </button>
                                <% } %>
                                <button onclick="window.location.href='/instances/detail/<%= task.instance_id %>'" class="action-btn" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border); font-size: 11px; padding: 6px 14px;">
                                    <i class="fas fa-eye"></i> Focus
                                </button>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="5" style="padding: 100px; text-align: center; color: var(--text-dim);">
                        <i class="fas fa-clipboard-check" style="font-size: 48px; margin-bottom: 24px; opacity: 0.1;"></i>
                        <p style="margin: 0; font-size: 16px; font-weight: 600;">Worklist is Clear</p>
                        <p style="margin: 8px 0 0 0; opacity: 0.6;">All tactical orchestrations have been processed or assigned.</p>
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<style>
    .tab-btn { background: transparent; border: none; color: var(--text-dim); padding: 8px 16px; border-radius: 8px; font-size: 11px; font-weight: 700; cursor: pointer; transition: all 0.2s; }
    .tab-btn.active { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3); }
</style>

<script>
    async function claimTask(taskId) {
        const res = await fetch('/api/tasks/claim', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ taskId })
        });
        if (res.ok) {
            ZeroModal.showSuccess('Task Successfully Claimed', 'The orchestration has been moved to your reserved workspace.');
            setTimeout(() => location.reload(), 2000);
        } else {
            alert('Claim failed: Task might be locked by another process.');
        }
    }
</script>
