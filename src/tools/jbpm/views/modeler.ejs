<!-- Zero-BPM Business Studio V6 (Industrial Premium Mode) -->
<link rel="stylesheet" href="https://unpkg.com/bpmn-js@17.0.2/dist/assets/diagram-js.css" />
<link rel="stylesheet" href="https://unpkg.com/bpmn-js@17.0.2/dist/assets/bpmn-font/css/bpmn.css" />

<style>
    /* V20.0 LIGHT STUDIO DESIGN SYSTEM */
    :root {
        --borealis: #1994ff;
        --borealis-glow: rgba(25, 148, 255, 0.22);
        --void-bg: #eef2f8;
        --glass-bg: rgba(255, 255, 255, 0.92);
        --glass-border: rgba(148, 163, 184, 0.2);
        --studio-panel: #ffffff;
        --studio-panel-soft: #f8fbff;
        --studio-text: #111827;
        --studio-text-dim: #667085;
        --studio-grid: rgba(15, 23, 42, 0.05);
    }

    .studio-container {
        height: calc(100vh - 210px);
        min-height: 720px;
        background:
            radial-gradient(circle at top left, rgba(25, 148, 255, 0.08), transparent 24%),
            linear-gradient(180deg, #f8fbff 0%, #eef2f8 100%);
        overflow: hidden;
        position: relative;
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 24px;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
    }

    /* Premium Glass Header */
    .studio-header {
        position: sticky; top: 0; z-index: 20;
        height: 72px; padding: 0 32px;
        background: var(--glass-bg); backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--glass-border);
        display: flex; align-items: center; justify-content: space-between;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
        flex: 0 0 auto;
    }

    .breadcrumb {
        display: flex; align-items: center; gap: 12px;
        font-size: 13px; font-weight: 600; color: var(--studio-text-dim);
    }
    .breadcrumb strong { color: var(--studio-text); font-weight: 800; }
    .breadcrumb .sep { opacity: 0.3; }
    .breadcrumb .tag-v { font-size: 10px; background: rgba(25, 148, 255, 0.1); color: var(--borealis); padding: 2px 8px; border-radius: 999px; border: 1px solid rgba(25, 148, 255, 0.16); }

    #header-actions { display: flex; gap: 16px; align-items: center; }
    .tactical-btn {
        height: 40px; padding: 0 16px; border-radius: 8px;
        font-size: 12px; font-weight: 700; border: 1px solid var(--glass-border);
        background: white; color: var(--studio-text);
        display: flex; align-items: center; gap: 10px; cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .tactical-btn:hover { background: #f8fbff; border-color: rgba(25, 148, 255, 0.18); transform: translateY(-1px); }
    .tactical-btn.primary { background: #12b76a; border: none; box-shadow: 0 12px 30px rgba(18, 183, 106, 0.22); color: white; }
    .tactical-btn.primary:hover { box-shadow: 0 0 25px var(--borealis-glow); transform: translateY(-1px) scale(1.02); }

    #canvas { 
        flex: 1 1 auto; background-color: #f8fbff;
        background-image: 
            radial-gradient(circle, var(--studio-grid) 1px, transparent 1px);
        background-size: 32px 32px;
        min-height: 0;
        height: 100%;
        position: relative;
    }

    #canvas .djs-container,
    #canvas .djs-container > svg {
        width: 100% !important;
        height: 100% !important;
    }

    .djs-palette { 
        background: var(--glass-bg) !important; 
        backdrop-filter: blur(20px) !important;
        border: 1px solid var(--glass-border) !important; 
        top: 92px !important; left: 24px !important; 
        width: 320px !important; border-radius: 20px !important;
        box-shadow: 0 24px 60px rgba(15,23,42,0.12) !important;
        max-height: calc(100% - 120px) !important;
        overflow-y: auto !important;
        overflow-x: hidden !important;
        padding-bottom: 20px !important;
        z-index: 30 !important;
        pointer-events: auto !important;
    }

    .djs-palette.palette-proxied .entry:not(.entry-industrial) { display: none !important; }
    
    .djs-palette .entry-industrial { 
        display: flex !important;
        width: 100% !important; height: 48px !important; 
        align-items: center !important; gap: 14px;
        padding: 0 20px !important;
        color: var(--studio-text-dim) !important;
        border-bottom: 1px solid rgba(148, 163, 184, 0.08);
        cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }
    
    .djs-palette .entry-industrial:hover { 
        color: var(--borealis) !important; 
        background: rgba(25,148,255,0.06) !important; 
    }

    .djs-palette .entry-industrial.active {
        color: var(--borealis) !important;
        background: rgba(25, 148, 255, 0.1) !important;
        border-right: 3px solid var(--borealis);
        box-shadow: inset 5px 0 15px -5px rgba(25, 148, 255, 0.3);
        font-weight: 600;
    }

    .djs-palette .entry-industrial::after {
        content: attr(title);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        font-size: 11px; font-weight: 700; letter-spacing: 0.4px;
        color: inherit;
    }

    .djs-palette::-webkit-scrollbar { width: 6px; }
    .djs-palette::-webkit-scrollbar-track { background: transparent; }
    .djs-palette::-webkit-scrollbar-thumb { background: rgba(148,163,184,0.22); border-radius: 999px; }
    
    /* V2 RADIANT LOADER */
    #zero-loader {
        position: fixed; inset: 0; z-index: 10001;
        background: rgba(248, 250, 252, 0.86); backdrop-filter: blur(25px);
        display: none; flex-direction: column; align-items: center; justify-content: center;
        color: var(--studio-text); gap: 32px; transition: all 0.5s ease;
    }
    .radiant-spinner {
        position: relative; width: 64px; height: 64px;
        border-radius: 50%; border: 3px solid rgba(25, 148, 255, 0.08);
        border-top: 3px solid var(--borealis);
        animation: spin 0.8s cubic-bezier(0.5, 0, 0.5, 1) infinite;
        box-shadow: 0 0 30px var(--borealis-glow);
    }
    #loader-msg { font-size: 15px; font-weight: 700; letter-spacing: 1px; color: var(--studio-text); text-transform: uppercase; opacity: 0.9; }

    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    /* Modal Styling */
    .modal-stack { display: flex; flex-direction: column; gap: 16px; margin-top: 16px; }
    .prop-group { border: 1px solid var(--glass-border); border-radius: 12px; background: #fcfdff; overflow: hidden; }
    .prop-group-header { background: #f8fbff; padding: 10px 16px; font-size: 10px; font-weight: 900; color: var(--borealis); text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid var(--glass-border); }
    .prop-group-body { padding: 16px; display: flex; flex-direction: column; gap: 12px; }

    .palette-cat-label {
        font-size: 8px; font-weight: 950; color: var(--borealis); text-align: left; padding: 16px 16px 8px 16px;
        letter-spacing: 2px; opacity: 0.8; text-transform: uppercase; border-bottom: 1px solid rgba(148,163,184,0.12);
        pointer-events: none; /* Ensure labels don't block node selection */
        user-select: none;
    }
    
    .palette-category-wrapper {
        display: flex;
        flex-direction: column;
        width: 100%;
        position: relative;
    }

    /* Node Anchor Styling */
    .djs-label { font-weight: 700 !important; font-size: 11px !important; fill: #344054 !important; }
    g.djs-element.djs-label {
        pointer-events: none !important;
    }
    /* Label background rect must be transparent so it doesn't flash white on re-render */
    g.djs-element.djs-label .djs-visual rect { fill: transparent !important; stroke: none !important; }
    /* Shape styling — scoped to non-label shapes only */
    g.djs-element.djs-shape:not(.djs-label) .djs-visual > rect,
    g.djs-element.djs-shape:not(.djs-label) .djs-visual > circle,
    g.djs-element.djs-shape:not(.djs-label) .djs-visual > polygon,
    g.djs-element.djs-shape:not(.djs-label) .djs-visual > path {
        stroke-width: 2px !important;
        stroke: rgba(25, 148, 255, 0.7) !important;
        fill: rgba(255, 255, 255, 0.96) !important;
    }
    /* Hover glow on shapes */
    g.djs-element.djs-shape:not(.djs-label):hover .djs-visual > rect,
    g.djs-element.djs-shape:not(.djs-label):hover .djs-visual > circle,
    g.djs-element.djs-shape:not(.djs-label):hover .djs-visual > polygon,
    g.djs-element.djs-shape:not(.djs-label):hover .djs-visual > path {
        stroke: rgba(25, 148, 255, 0.95) !important;
        filter: drop-shadow(0 0 6px rgba(25, 148, 255, 0.18));
    }

    /* Industrial Context Pad Sovereign Design */
    .djs-context-pad .entry { 
        background: rgba(255, 255, 255, 0.98) !important; 
        color: var(--studio-text) !important; 
        border-radius: 8px !important; 
        box-shadow: 0 10px 24px rgba(15,23,42,0.12) !important;
        border: 1px solid var(--glass-border) !important;
    }
    .djs-context-pad .entry:hover { 
        background: var(--borealis) !important; 
        color: white !important;
    }
    
    .modal-scroll-area {
        max-height: 65vh;
        overflow-y: auto;
        padding-right: 12px;
        margin-right: -12px;
    }
    .modal-scroll-area::-webkit-scrollbar { width: 4px; }
    .modal-scroll-area::-webkit-scrollbar-track { background: transparent; }
    .modal-scroll-area::-webkit-scrollbar-thumb { background: rgba(148,163,184,0.18); border-radius: 10px; }
    
    .docs-section {
        background: rgba(25, 148, 255, 0.04);
        border: 1px solid rgba(25, 148, 255, 0.1);
        border-radius: 12px;
        padding: 16px;
        margin-top: 16px;
        font-size: 12px;
        line-height: 1.6;
        color: #475467;
    }
    .docs-section h3 { font-size: 10px; font-weight: 900; text-transform: uppercase; color: var(--borealis); margin-bottom: 8px; }
    .docs-section p { margin-bottom: 8px; }
    .docs-section code { background: rgba(148,163,184,0.12); padding: 2px 4px; border-radius: 4px; font-family: monospace; color:#0f172a; }

    /* Premium Property Surface */
    #global-modal .modal-content {
        max-width: 1040px;
        width: min(88vw, 1040px);
        max-height: 86vh;
        overflow: hidden;
        padding: 0;
        border-radius: 24px;
        background: linear-gradient(180deg, rgba(255,255,255,0.99) 0%, rgba(248,250,252,0.99) 100%);
        border: 1px solid rgba(148,163,184,0.18);
        box-shadow: 0 32px 100px rgba(15,23,42,0.18), inset 0 1px 0 rgba(255,255,255,0.7);
    }
    #global-modal .modal-header {
        margin: 0;
        padding: 22px 28px 14px 28px;
        border-bottom: 1px solid rgba(148,163,184,0.12);
        background: linear-gradient(180deg, rgba(248,250,252,0.9), rgba(255,255,255,0.82));
    }
    #global-modal .modal-scroll-area {
        max-height: calc(86vh - 160px);
        padding: 18px 28px 10px 28px;
        margin: 0;
    }
    #global-modal .modal-stack {
        gap: 14px;
    }
    #global-modal .form-group {
        margin-bottom: 0;
    }
    #global-modal .form-label {
        margin-bottom: 10px;
        font-size: 11px;
        font-weight: 900;
        letter-spacing: 0.7px;
        color: #667085;
    }
    #global-modal .form-input {
        min-height: 52px;
        background: #ffffff;
        border: 1px solid rgba(148,163,184,0.2);
        border-radius: 14px;
        color: #111827;
        padding: 12px 14px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
    }
    #global-modal .form-input:focus {
        border-color: rgba(25, 148, 255, 0.75);
        box-shadow: 0 0 0 4px rgba(25, 148, 255, 0.12), inset 0 1px 0 rgba(255,255,255,0.8);
    }
    #global-modal textarea.form-input {
        min-height: 144px;
        resize: vertical;
    }
    .prop-group {
        border: 1px solid rgba(148,163,184,0.16);
        border-radius: 18px;
        background: #ffffff;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
    }
    .prop-group-header {
        background: #f8fbff;
        padding: 13px 16px;
        font-size: 11px;
        font-weight: 950;
        color: var(--borealis);
        letter-spacing: 1.4px;
        border-bottom: 1px solid rgba(148,163,184,0.12);
    }
    .prop-group-body {
        padding: 16px 16px;
        gap: 12px;
    }
    .premium-kv {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .premium-kv-row {
        display: flex;
        gap: 10px;
        align-items: center;
    }
    .premium-kv-main {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }
    .premium-kv-row-variable .premium-kv-main {
        grid-template-columns: 1.15fr 140px 0.95fr;
    }
    .premium-kv-mapping-main {
        grid-template-columns: minmax(0, 1fr) 28px minmax(0, 1fr) 116px;
        align-items: center;
    }
    .premium-kv-col {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .premium-kv-meta {
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 0.8px;
        color: #667085;
        text-transform: uppercase;
    }
    .premium-kv-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--borealis);
        font-size: 15px;
        opacity: 0.85;
    }
    .premium-kv-type {
        text-transform: capitalize;
        min-height: 46px !important;
        padding: 10px 12px !important;
    }
    .premium-kv-delete {
        width: 44px;
        min-width: 44px;
        height: 44px;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        background: #f8fafc;
        color: #ef4444;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .premium-kv-delete:hover {
        background: rgba(239, 68, 68, 0.08);
        border-color: rgba(239, 68, 68, 0.22);
        color: #dc2626;
    }
    .premium-add-btn {
        align-self: flex-start;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid rgba(25, 148, 255, 0.16);
        border-radius: 999px;
        background: rgba(25, 148, 255, 0.08);
        color: var(--borealis);
        font-size: 11px;
        font-weight: 800;
        padding: 9px 13px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .premium-add-btn:hover {
        background: rgba(25, 148, 255, 0.14);
        transform: translateY(-1px);
    }
    .premium-kv-hint {
        font-size: 10px;
        color: #667085;
        opacity: 0.82;
        line-height: 1.45;
    }
    .premium-kv-endpoint {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }
    .premium-kv-endpoint-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 0.8px;
        color: #667085;
        text-transform: uppercase;
    }
    .premium-kv-endpoint-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 20px;
        padding: 0 8px;
        border-radius: 999px;
        font-size: 9px;
        font-weight: 900;
        letter-spacing: 0.5px;
        color: #0b6dcf;
        background: rgba(25, 148, 255, 0.08);
        border-color: rgba(25, 148, 255, 0.18);
        border: 1px solid rgba(25, 148, 255, 0.18);
    }
    .premium-kv-endpoint-badge-muted {
        color: #667085;
        background: rgba(148, 163, 184, 0.08);
        border-color: rgba(148, 163, 184, 0.18);
    }
    .premium-kv-endpoint-body {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .premium-kv-combo {
        min-height: 46px !important;
        padding: 10px 12px !important;
        border-radius: 13px !important;
    }
    .premium-snippet-input {
        min-height: 220px !important;
        resize: vertical;
        font-family: "SFMono-Regular", "JetBrains Mono", "Fira Code", monospace;
        font-size: 12px;
        line-height: 1.6;
        white-space: pre;
        tab-size: 2;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.98)),
            repeating-linear-gradient(
                180deg,
                rgba(15,23,42,0.015) 0,
                rgba(15,23,42,0.015) 28px,
                rgba(15,23,42,0.025) 28px,
                rgba(15,23,42,0.025) 29px
            );
    }
    .premium-snippet-footer {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-top: 6px;
        font-size: 10px;
        color: #667085;
        opacity: 0.88;
    }
    .zero-autocomplete {
        position: relative;
    }
    .zero-autocomplete-panel {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        right: 0;
        z-index: 30;
        max-height: 220px;
        overflow: auto;
        padding: 8px;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.98);
        border: 1px solid rgba(148,163,184,0.16);
        box-shadow: 0 20px 50px rgba(15,23,42,0.16);
        backdrop-filter: blur(14px);
    }
    .zero-autocomplete-group + .zero-autocomplete-group {
        margin-top: 8px;
        padding-top: 8px;
        border-top: 1px solid rgba(148,163,184,0.1);
    }
    .zero-autocomplete-group-label {
        margin: 0 6px 6px;
        font-size: 9px;
        font-weight: 900;
        letter-spacing: 0.8px;
        color: var(--borealis);
        text-transform: uppercase;
    }
    .zero-autocomplete-item {
        width: 100%;
        display: flex;
        align-items: center;
        padding: 9px 10px;
        border: 0;
        border-radius: 10px;
        background: transparent;
        color: #111827;
        text-align: left;
        cursor: pointer;
        transition: background 0.16s ease;
    }
    .zero-autocomplete-item:hover {
        background: rgba(25, 148, 255, 0.1);
    }
    .zero-autocomplete-item-value {
        font-size: 12px;
        line-height: 1.35;
        word-break: break-word;
    }

    /* Selection Highlighting for Industrial Precision */
    .djs-element.selected .djs-outline { stroke: var(--borealis) !important; stroke-width: 2px !important; }

    /* Pruning clutter for cleaner industrial workspace */
    .djs-context-pad [data-action="append.intermediate-event"],
    .djs-context-pad [data-action="append.text-annotation"],
    .djs-context-pad [data-action="replace"] { display: none !important; }

    @media (max-width: 900px) {
        .studio-container {
            height: calc(100vh - 180px);
            min-height: 560px;
            border-radius: 18px;
        }

        .studio-header {
            padding: 16px 18px;
            height: auto;
            align-items: flex-start;
            flex-direction: column;
            gap: 14px;
        }

        #header-actions {
            width: 100%;
            flex-wrap: wrap;
        }

        #canvas {
            min-height: 0;
        }

        .djs-palette {
            width: min(260px, calc(100vw - 32px)) !important;
            left: 16px !important;
            top: 102px !important;
            max-height: calc(100% - 132px) !important;
        }
    }
</style>

<div class="studio-container">
    <div class="studio-header">
        <div class="breadcrumb">
            <i class="fas fa-microchip" style="color: var(--borealis); font-size: 18px;"></i>
            <span class="sep">/</span>
            <strong><%= projectName %></strong>
            <span class="sep">/</span>
            <span style="opacity: 0.7;"><%= intent.name %></span>
            <span class="tag-v">V<%= intent.version %></span>
        </div>
        <div id="header-actions"></div>
    </div>

    <!-- Reactive Tooltip Overlay -->
    <div id="zero-tooltip" style="position: fixed; display: none; z-index: 1000; width: 280px; background: rgba(255, 255, 255, 0.98); border: 1px solid rgba(25, 148, 255, 0.18); padding: 16px; border-radius: 12px; box-shadow: 0 20px 50px rgba(15,23,42,0.16); backdrop-filter: blur(15px); pointer-events: none; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);">
        <div id="tt-label" style="font-size: 14px; font-weight: 950; color: #111827; margin-bottom: 8px; display: flex; align-items: center; gap: 8px;"></div>
        <div id="tt-desc" style="font-size: 11px; color: #667085; line-height: 1.6; margin-bottom: 12px;"></div>
        <div id="tt-badge" style="display: inline-block; font-size: 9px; font-weight: 900; padding: 2px 8px; border-radius: 999px; background: rgba(25, 148, 255, 0.1); color: var(--borealis); text-transform: uppercase; border: 1px solid rgba(25, 148, 255, 0.14);"></div>
    </div>

    <!-- Policy Violation Notification Overlay -->
    <div id="policy-alert" style="position: fixed; top: 100px; left: 50%; transform: translateX(-50%) translateY(-20px); z-index: 2000; background: rgba(255, 244, 242, 0.98); border-left: 4px solid #ef4444; color: #7a271a; padding: 16px 24px; border-radius: 8px; box-shadow: 0 30px 60px rgba(15,23,42,0.16); backdrop-filter: blur(10px); display: none; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); gap: 16px; align-items: center;">
        <i class="fas fa-exclamation-triangle" style="font-size: 20px; color: #fecaca;"></i>
        <div>
            <div style="font-weight: 900; font-size: 13px; letter-spacing: 0.5px;">INDUSTRIAL POLICY VIOLATION</div>
            <div id="policy-msg" style="font-size: 11px; opacity: 0.9; margin-top: 2px;"></div>
        </div>
    </div>

    <!-- Industrial Loader Overlay -->
    <div id="zero-loader">
        <div class="radiant-spinner"></div>
        <div id="loader-msg">Industrial Synchronization In Progress...</div>
    </div>

    <div id="canvas"></div>
</div>

<script src="https://unpkg.com/bpmn-js@17.0.2/dist/bpmn-modeler.production.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="/widgets.js"></script>
<script>
    const zeroModdle = {
        "name": "Zero",
        "uri": "http://zero-bpm.ai/schema/bpmn",
        "prefix": "zero",
        "xml": { "tagAlias": "lowerCase" },
        "types": [
            {
                "name": "ExtElement",
                "extends": ["bpmn:BaseElement"],
                "properties": [{ "name": "nodeId", "isAttr": true, "type": "String" }]
            }
        ]
    };

    const modeler = new BpmnJS({ 
        container: '#canvas',
        moddleExtensions: { zero: zeroModdle }
    });
    let selectedElement = null;
    let propertyMap = <%- asset && asset.json_config ? JSON.stringify(asset.json_config) : '{}' %>;
    const nodeRegistry = <%- JSON.stringify(nodeRegistryContext) %>;
    const intent = <%- JSON.stringify(intent) %>;
    const projectName = "<%= projectName %>";
    const projectAssets = <%- JSON.stringify(projectAssets || []) %>;
    const existingXml = <%- asset ? JSON.stringify(asset.bpmn_xml) : 'null' %>;
    const assetContractCache = {};
    let paletteRoot = null;
    let canvasRoot = null;

    const FIELD_GROUP_LABELS = {
        general: 'General',
        trigger: 'Trigger',
        assignment: 'Assignment',
        variables: 'Variables',
        mapping: 'Mappings',
        runtime: 'Runtime',
        advanced: 'Advanced'
    };

    async function init() {
        document.getElementById('header-actions').innerHTML = `
            <button onclick="openProjectSettingsFromStudio()" class="tactical-btn"><i class="fas fa-cog"></i> Settings</button>
            <button onclick="persistProcess(false)" class="tactical-btn"><i class="fas fa-save"></i> Save Draft</button>
            <button onclick="persistProcess(true)" class="tactical-btn primary"><i class="fas fa-rocket"></i> Release & Deploy</button>
        `;

        try {
            await importStudioXml();
            
            setupCategorizedPalette();
            stabilizeCanvasViewport();

            canvasRoot = modeler.get('canvas').getContainer();

            window.addEventListener('resize', stabilizeCanvasViewport);
            requestAnimationFrame(() => stabilizeCanvasViewport());
            setTimeout(() => stabilizeCanvasViewport(), 180);
            setTimeout(() => stabilizeCanvasViewport(), 420);
            try {
                bindStudioBehaviors();
            } catch (behaviorError) {
                console.error('Studio behavior setup failed:', behaviorError);
            }

        } catch (err) {
            console.error('Initialization Failure:', err);
            try {
                setupCategorizedPalette();
            } catch (paletteError) {
                console.error('Fallback palette render failed:', paletteError);
            }
            const palette = document.querySelector('.djs-palette');
            if (palette && !palette.innerHTML.trim()) {
                palette.innerHTML = `<div style="padding:18px; color:var(--studio-text-dim); font-size:12px; line-height:1.5;">Studio initialization failed. Refresh the page or reopen the project to recover the palette.</div>`;
            }
        }
    }

    async function importStudioXml() {
        const isNewAsset = !existingXml;
        const primaryXml = existingXml || getDefaultXml();
        try {
            await modeler.importXML(primaryXml);
        } catch (importError) {
            console.error('Primary BPMN import failed, falling back to default XML:', importError);
            try {
                await modeler.importXML(getDefaultXml());
            } catch (defaultImportError) {
                console.error('Default BPMN import failed, creating fresh diagram instead:', defaultImportError);
                await modeler.createDiagram();
            }
        }
        normalizeStarterNodes(isNewAsset);
    }

    function findNodePackageByType(bpmnType, preferredId = null) {
        if (preferredId && nodeRegistry[preferredId]) return nodeRegistry[preferredId];
        const matches = Object.values(nodeRegistry || {}).filter(pkg => pkg && pkg.bpmnType === bpmnType);
        if (!matches.length) return null;
        if (preferredId) {
            const exact = matches.find(pkg => pkg.id === preferredId);
            if (exact) return exact;
        }
        return matches[0];
    }

    function buildDefaultConfig(pkg, elementId) {
        const config = {};
        (pkg?.fields || []).forEach(field => {
            if (field.default !== undefined) {
                config[field.key] = field.default;
                return;
            }
            if (field.key === 'name') {
                config[field.key] = intent.name || pkg.label || 'Start Process';
                return;
            }
            if (field.type === 'keyvalue') {
                config[field.key] = {};
                return;
            }
            if (field.type === 'snippet') {
                config[field.key] = '';
            }
        });
        return enrichConfig(pkg, config);
    }

    function normalizeStarterNodes(isNewAsset) {
        const elementRegistry = modeler.get('elementRegistry');
        const modeling = modeler.get('modeling');
        const startElements = elementRegistry.filter(element => element.type === 'bpmn:StartEvent' && !element.labelTarget);
        if (!startElements.length) return;

        startElements.forEach((startElement, index) => {
            const bo = startElement.businessObject;
            const pkg = findNodePackageByType('bpmn:StartEvent', 'start-event');
            if (!pkg) return;

            const nextProps = {};
            if (!bo.nodeId || isNewAsset) nextProps.nodeId = pkg.id;
            if ((!bo.name || bo.name === 'Initiated') && isNewAsset && index === 0) {
                nextProps.name = 'Start Process';
            }
            if (Object.keys(nextProps).length > 0) {
                modeling.updateProperties(startElement, nextProps);
            }

            if (!propertyMap[bo.id] || isNewAsset) {
                propertyMap[bo.id] = buildDefaultConfig(pkg, bo.id);
            } else if (!propertyMap[bo.id].__nodeMeta) {
                propertyMap[bo.id] = {
                    ...propertyMap[bo.id],
                    ...enrichConfig(pkg, propertyMap[bo.id])
                };
            }
        });
    }

    function bindStudioBehaviors() {
        modeler.on('element.dblclick', (e) => {
            selectedElement = e.element;
            openPropertyModal(null, e.element.type === 'bpmn:Process' ? 'process-definitions' : null);
        });

        modeler.on('selection.changed', (event) => {
            const nextSelection = event.newSelection || [];
            const next = nextSelection[0];
            if (!next) {
                selectedElement = null;
                return;
            }
            selectedElement = next.labelTarget || next;
        });

        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                try { modeler.get('dragging').cancel(); } catch(err) {}
                try { modeler.get('selection').select(null); } catch(err) {}
            }
        });

        modeler.on('commandStack.shape.create.canExecute', (e) => {
            const { shape } = e.context;
            if (shape.type === 'bpmn:StartEvent') {
                const starts = modeler.get('elementRegistry').filter(e => e.type === 'bpmn:StartEvent');
                if (starts.length >= 1) {
                    showPolicyAlert("Zero-BPM Industrial Policy: Single Entry Point Required. Multiple genesis nodes are prohibited.");
                    return false; 
                }
            }
        });

        modeler.on('shape.added', (e) => {
            const shape = e.element;
            if (shape.type === 'bpmn:StartEvent') {
                const starts = modeler.get('elementRegistry').filter(e => e.type === 'bpmn:StartEvent');
                if (starts.length > 1) {
                    setTimeout(() => {
                        try {
                            modeler.get('modeling').removeShape(shape);
                            showPolicyAlert("Zero-BPM Industrial Policy: Transactional purge of redundant start node completed.");
                        } catch (err) {}
                    }, 0);
                }
            }
        });

        modeler.get('eventBus').on('commandStack.elements.move.preExecute', (e) => {
            const { shapes } = e.context;
            const labelsToAdd = [];
            shapes.forEach(s => {
                const label = s.label || (s.attachers && s.attachers.find(a => a.type === 'label'));
                if (label && !shapes.includes(label)) labelsToAdd.push(label);
            });
            e.context.shapes = [...shapes, ...labelsToAdd];
        });

        modeler.on('element.mousedown', 5000, (event) => {
            if (!event.element || !event.element.labelTarget) return;
            selectedElement = event.element.labelTarget;
            try { modeler.get('selection').select(event.element.labelTarget); } catch (e) {}
            return false;
        });

        window.onZeroModalToggle = (isOpen) => {
            if (isOpen) return;
            requestAnimationFrame(() => {
                try { modeler.get('canvas').resized(); } catch (e) {}
            });
        };
    }

    function stabilizeCanvasViewport() {
        try {
            const canvasEl = document.getElementById('canvas');
            if (!canvasEl) return;
            const rect = canvasEl.getBoundingClientRect();
            if (!rect.width || !rect.height || !Number.isFinite(rect.width) || !Number.isFinite(rect.height)) return;
            modeler.get('canvas').resized();
            modeler.get('canvas').zoom('fit-viewport', 'auto');
        } catch (e) {}
    }

    function openProjectSettingsFromStudio() {
        location.href = `/projectSettings?projectName=${projectName}`;
    }

    function showPolicyAlert(msg) {
        document.getElementById('policy-msg').innerText = msg;
        const alert = document.getElementById('policy-alert');
        alert.style.display = 'flex';
        setTimeout(() => alert.style.display = 'none', 5000);
    }

    function getDefaultXml() {
        const id = intent.name.replace(/\s+/g, '-');
        return `<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="${id}" name="${intent.name}" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start Process" nodeId="start-event" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1"><bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="${id}"><bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1"><dc:Bounds x="173" y="102" width="36" height="36" /></bpmndi:BPMNShape></bpmndi:BPMNPlane></bpmndi:BPMNDiagram>
</bpmn:definitions>`;
    }

    function setupCategorizedPalette() {
        const palette = document.querySelector('.djs-palette');
        if (!palette) return;
        paletteRoot = palette;
        palette.innerHTML = '';
        palette.classList.remove('palette-proxied');
        const order = ['EVENT', 'GATEWAY', 'TASK', 'SUITE', 'SYSTEM'];
        const cats = {};

        Object.values(nodeRegistry || {}).forEach(pkg => {
            if (pkg.bpmnType === 'bpmn:SequenceFlow') return; // Flows must be created via Global Connect or Context Pad
            const categoryName = String(pkg.category || 'TASK').toUpperCase();
            if (!cats[categoryName]) cats[categoryName] = [];
            cats[categoryName].push({ type: 'dynamic', ...pkg, category: categoryName });
        });

        if (Object.keys(cats).length === 0) {
            const fallbackEntries = [
                { id: 'start-event', label: 'Start Process', title: 'Start Process', category: 'EVENT', bpmnType: 'bpmn:StartEvent', icon: 'fa-circle-play', documentation: { desc: 'Start the workflow.' } },
                { id: 'end-event', label: 'End Process', title: 'End Process', category: 'EVENT', bpmnType: 'bpmn:EndEvent', icon: 'fa-circle-stop', documentation: { desc: 'End the workflow.' } },
                { id: 'script-task', label: 'Script Task', title: 'Script Task', category: 'TASK', bpmnType: 'bpmn:ScriptTask', icon: 'fa-code', documentation: { desc: 'Execute inline logic.' } },
                { id: 'user-task', label: 'User Task', title: 'User Task', category: 'TASK', bpmnType: 'bpmn:UserTask', icon: 'fa-user', documentation: { desc: 'Wait for human work.' } },
                { id: 'exclusive-gateway', label: 'Exclusive Junction', title: 'Exclusive Junction', category: 'GATEWAY', bpmnType: 'bpmn:ExclusiveGateway', icon: 'fa-code-branch', documentation: { desc: 'Branch on conditions.' } }
            ];
            fallbackEntries.forEach(pkg => {
                if (!cats[pkg.category]) cats[pkg.category] = [];
                cats[pkg.category].push(pkg);
            });
        }

        const derivedOrder = [...order, ...Object.keys(cats).filter(cat => !order.includes(cat))];
        let totalRendered = 0;

        derivedOrder.forEach(catName => {
            if (!cats[catName] || cats[catName].length === 0) return;
            
            const catWrapper = document.createElement('div');
            catWrapper.className = 'palette-category-wrapper';
            
            const header = document.createElement('div');
            header.className = 'palette-cat-label';
            header.innerText = catName;
            catWrapper.appendChild(header);

            cats[catName].forEach(asset => {
                const entry = document.createElement('div');
                entry.className = 'entry entry-industrial';
                entry.title = asset.title || asset.label;
                
                const isUrl = asset.icon && (asset.icon.startsWith('/') || asset.icon.includes('.'));
                if (isUrl) {
                    entry.innerHTML = `
                        <div style="width: 18px; height: 18px; background: var(--borealis); -webkit-mask: url(${asset.icon}) no-repeat center; mask: url(${asset.icon}) no-repeat center; -webkit-mask-size: contain; mask-size: contain;"></div>
                    `;
                } else {
                    entry.innerHTML = `
                        <i class="fas ${asset.icon || 'fa-cube'}" style="font-size: 14px; width: 20px; text-align: center; color: var(--borealis);"></i>
                    `;
                }
                
                entry.onmousedown = (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    const shape = modeler.get('elementFactory').createShape({ type: asset.bpmnType, ...asset.bpmnOptions });
                    shape.businessObject.nodeId = asset.id;
                    modeler.get('create').start(e, shape);
                };

                entry.onmouseenter = () => { if (asset.type === 'dynamic') showTooltip(entry, asset); };
                entry.onmouseleave = hideTooltip;
                catWrapper.appendChild(entry);
                totalRendered += 1;
            });
            palette.appendChild(catWrapper);
        });

        if (totalRendered > 0) {
            palette.classList.add('palette-proxied');
        } else {
            palette.innerHTML = `<div style="padding:18px; color:var(--studio-text-dim); font-size:12px; line-height:1.5;">No node packages are currently available in the studio palette.</div>`;
        }
    }

    function showTooltip(entry, pkg) {
        const tt = document.getElementById('zero-tooltip');
        document.getElementById('tt-label').innerHTML = `<i class="fas ${pkg.icon}" style="color:var(--borealis);"></i> ${pkg.label}`;
        document.getElementById('tt-desc').innerText = pkg.documentation.desc;
        document.getElementById('tt-badge').innerText = pkg.category;
        tt.style.display = 'block';
        const rect = entry.getBoundingClientRect();
        tt.style.left = (rect.right + 20) + 'px';
        tt.style.top = rect.top + 'px';
    }

    function hideTooltip() { document.getElementById('zero-tooltip').style.display = 'none'; }

    function inferFieldGroup(field) {
        if (field.group) return field.group;
        if ((field.key || '').toLowerCase().includes('mapping') || (field.key || '').toLowerCase().includes('map')) return 'mapping';
        if ((field.key || '').toLowerCase().includes('variable')) return 'variables';
        if (['assignee', 'candidateGroups', 'candidateUsers', 'formKey', 'priority'].includes(field.key)) return 'assignment';
        if ((field.key || '').toLowerCase().includes('trigger') || (field.key || '').toLowerCase().includes('cron') || (field.key || '').toLowerCase().includes('message')) return 'trigger';
        if ((field.key || '').toLowerCase().includes('retry') || (field.key || '').toLowerCase().includes('timeout')) return 'runtime';
        return 'general';
    }

    function getEffectiveField(field) {
        const key = String(field.key || '').toLowerCase();
        const next = { ...field };

        if (!next.group) {
            next.group = inferFieldGroup(field);
        }

        if (!next.mapping && next.type === 'keyvalue') {
            if (['outputmapping', 'outboundmapping', 'responsemap'].includes(key)) {
                next.mapping = { typed: true, sourceScope: 'process', targetScope: 'output' };
            } else if (['inputmapping', 'inboundmapping', 'inputmap', 'params'].includes(key)) {
                next.mapping = { typed: true, sourceScope: 'process', targetScope: 'input' };
            }
        }

        if (!next.variableRef) {
            if (['resultvariable', 'assignee', 'candidategroups', 'candidateusers'].includes(key)) {
                next.variableRef = true;
            }
        }

        return next;
    }

    function groupFields(fields) {
        const buckets = {};
        fields.forEach(field => {
            const effectiveField = getEffectiveField(field);
            const group = inferFieldGroup(effectiveField);
            if (!buckets[group]) buckets[group] = [];
            buckets[group].push(effectiveField);
        });
        return ['general', 'trigger', 'assignment', 'variables', 'mapping', 'runtime', 'advanced']
            .filter(group => buckets[group] && buckets[group].length > 0)
            .map(group => ({ id: group, label: FIELD_GROUP_LABELS[group], fields: buckets[group] }));
    }

    function isBlankValue(value) {
        if (value === null || value === undefined) return true;
        if (typeof value === 'string') return value.trim() === '';
        if (Array.isArray(value)) return value.length === 0;
        if (typeof value === 'object') return Object.keys(value).length === 0;
        return false;
    }

    function validateFieldValue(field, value) {
        const issues = [];

        if (field.required && isBlankValue(value)) {
            issues.push(`${field.label} is required.`);
            return issues;
        }

        if (isBlankValue(value)) return issues;

        if (field.type === 'number' && Number.isNaN(Number(value))) {
            issues.push(`${field.label} must be a valid number.`);
        }

        if (field.type === 'keyvalue' && (typeof value !== 'object' || Array.isArray(value))) {
            issues.push(`${field.label} must be a key/value object.`);
        }

        if (field.dataType === 'json' && typeof value === 'string') {
            try { JSON.parse(value); } catch (e) { issues.push(`${field.label} must be valid JSON.`); }
        }

        if (field.dataType === 'cron' && typeof value === 'string') {
            const parts = value.trim().split(/\s+/);
            if (parts.length < 5 || parts.length > 7) issues.push(`${field.label} must look like a CRON expression.`);
        }

        if (field.dataType === 'url' && typeof value === 'string' && !value.includes('${')) {
            try { new URL(value); } catch (e) { issues.push(`${field.label} must be a valid URL.`); }
        }

        if (field.options && field.type === 'select' && !field.options.includes(value)) {
            issues.push(`${field.label} must be one of: ${field.options.join(', ')}.`);
        }

        if (field.mapping && typeof value === 'object' && value) {
            Object.entries(value).forEach(([k, v]) => {
                const targetValue = (v && typeof v === 'object' && !Array.isArray(v)) ? (v.target ?? '') : v;
                if (!k || !String(k).trim() || !String(targetValue || '').trim()) {
                    issues.push(`${field.label} has an empty mapping row.`);
                }
            });
        }

        return [...new Set(issues)];
    }

    function collectFieldValues(bo, pkg) {
        const config = {};
        if (pkg && pkg.fields) {
            pkg.fields.forEach(f => {
                try { config[f.key] = eval(ZeroWidgets.getExtractionLogic(f.type, bo.id, f.key)); } catch (e) {}
            });
        }
        return config;
    }

    function validateConfig(pkg, config) {
        const issues = [];
        if (!(pkg && pkg.fields)) return issues;
        pkg.fields.forEach(field => {
            const effectiveField = getEffectiveField(field);
            validateFieldValue(effectiveField, config[field.key]).forEach(message => {
                issues.push({ fieldKey: field.key, message });
            });
        });
        return issues;
    }

    function enrichConfig(pkg, config) {
        return {
            ...config,
            __nodeMeta: pkg ? {
                pkgId: pkg.id,
                bpmnType: pkg.bpmnType,
                label: pkg.label
            } : undefined
        };
    }

    function openPropertyModal(liveState = null, forcedPkgId = null) {
        const bo = selectedElement.businessObject;
        const pkgId = forcedPkgId || bo.nodeId || selectedElement.type;
        const pkg = nodeRegistry[pkgId] || nodeRegistry[selectedElement.type];
        if (!propertyMap[bo.id]) propertyMap[bo.id] = {};
        if (!liveState) liveState = { ...propertyMap[bo.id] };

        const issues = validateConfig(pkg, liveState);
        let fieldsHtml = '';
        if (pkg && pkg.fields) {
            groupFields(pkg.fields).forEach(group => {
                let groupBody = '';
                group.fields.forEach(f => {
                if (f.visibility) {
                    try { if (!new Function('ctx', `with(ctx) { return ${f.visibility} }`)(liveState)) return; } catch (e) {}
                }
                    const fieldIssues = issues.filter(issue => issue.fieldKey === f.key);
                    groupBody += renderField(f, liveState[f.key], bo.id, liveState, fieldIssues);
                });
                if (groupBody) {
                    fieldsHtml += `
                        <div class="prop-group">
                            <div class="prop-group-header">${group.label}</div>
                            <div class="prop-group-body">${groupBody}</div>
                        </div>
                    `;
                }
            });
        }

        const issueHtml = issues.length > 0 ? `
            <div class="docs-section" style="border-color: rgba(248, 113, 113, 0.35); background: rgba(127, 29, 29, 0.22);">
                <h3><i class="fas fa-shield-alt"></i> Validation</h3>
                <div>${issues.map(issue => `<div style="margin-bottom:6px;">${issue.message}</div>`).join('')}</div>
            </div>
        ` : '';

        const summaryHtml = pkg && pkg.documentation ? `
            <div class="docs-section">
                <h3><i class="fas fa-compass"></i> Node Summary</h3>
                <div>${marked.parse(pkg.documentation.desc || '')}</div>
                ${pkg.documentation.flow ? `<div style="margin-top:8px; font-style:italic; opacity:0.8;">Flow: ${pkg.documentation.flow}</div>` : ''}
            </div>
        ` : '';

        const nodeDocHtml = pkg && pkg.readme ? `
            <div class="docs-section">
                <h3><i class="fas fa-book-open"></i> Node Document</h3>
                <div>${marked.parse(pkg.readme)}</div>
            </div>
        ` : '';

        const docsHtml = nodeDocHtml || summaryHtml ? `${summaryHtml}${nodeDocHtml}` : '';

        const html = `
            <div class="modal-header">
                <h2><i class="fas ${pkg ? pkg.icon : 'fa-cog'}" style="color:var(--borealis);"></i> ${pkg ? pkg.label : 'Configuration'}</h2>
                <div style="font-size:10px; opacity:0.5; font-family:monospace;">ID: ${bo.id}</div>
            </div>
            <div class="modal-scroll-area">
                <div class="modal-stack" oninput="debounceRefresh()" onchange="debounceRefresh()">
                    <div class="form-group">
                        <label class="form-label">Alias</label>
                        <input type="text" id="m-node-name" class="form-input" value="${bo.name || ''}" oninput="syncNameFromModal(this.value)">
                    </div>
                    ${fieldsHtml}
                </div>
                ${issueHtml}
                ${docsHtml}
            </div>
            <div style="display:flex; justify-content:flex-end; gap:12px; margin-top:24px;">
                <button onclick="ZeroModal.close()" class="tactical-btn">Discard</button>
                <button onclick="saveAndClose('${bo.id}')" class="tactical-btn primary">Commit Changes</button>
            </div>
        `;
        ZeroModal.open(html);
    }

    let refreshTimer = null;
    function debounceRefresh() {
        if (refreshTimer) clearTimeout(refreshTimer);
        refreshTimer = setTimeout(refreshPropertyModal, 1200); // 1.2s delay to prevent typing interference
    }

    function refreshPropertyModal() {
        const focusedId = document.activeElement ? document.activeElement.id : null;
        const ss = document.activeElement ? document.activeElement.selectionStart : null;
        const scrollPos = document.querySelector('.modal-scroll-area') ? document.querySelector('.modal-scroll-area').scrollTop : 0;
        
        const bo = selectedElement.businessObject;
        const pkgId = bo.nodeId || bo.$type;
        const pkg = nodeRegistry[pkgId];
        const liveState = collectFieldValues(bo, pkg);
        
        // Critical: Update propertyMap live so suggestions work mid-edit
        propertyMap[bo.id] = enrichConfig(pkg, liveState);

        openPropertyModal(liveState);
        if (focusedId) {
            const el = document.getElementById(focusedId);
            if (el) { 
                el.focus(); 
                if (ss !== null && el.setSelectionRange) el.setSelectionRange(ss, ss); 
            }
        }
        if (document.querySelector('.modal-scroll-area')) {
            document.querySelector('.modal-scroll-area').scrollTop = scrollPos;
        }
    }

    function renderField(f, currentVal, nodeId, liveState, issues = []) {
        const effectiveField = getEffectiveField(f);
        const suggestions = discoverSuggestions(effectiveField, liveState);
        const mappingSuggestions = effectiveField.mapping ? discoverMappingSuggestions(effectiveField, liveState) : null;
        const datalistId = `list-${nodeId}-${f.key}`;
        let html = ZeroWidgets.render(effectiveField.type, { 
            ...effectiveField, 
            value: currentVal !== undefined ? currentVal : (effectiveField.default || ''), 
            nodeId: nodeId,
            datalistId: suggestions.length > 0 ? datalistId : null,
            suggestions,
            mappingSuggestions
        }, liveState);
        if (effectiveField.mapping) {
            html += `<div style="font-size:10px; opacity:0.65; margin-top:6px;">Mapping: ${(effectiveField.mapping.sourceScope || 'source')} -> ${(effectiveField.mapping.targetScope || 'target')}</div>`;
        }
        if (issues.length > 0) {
            html += `<div style="margin-top:6px; font-size:10px; color:#fca5a5;">${issues.map(issue => issue.message).join('<br>')}</div>`;
        }
        return html;
    }

    function safeParseJson(value) {
        if (!value || typeof value !== 'string') return null;
        try {
            return JSON.parse(value);
        } catch (e) {
            return null;
        }
    }

    function pushSuggestion(bucket, value, group = 'Suggestions') {
        const normalized = String(value || '').trim();
        if (!normalized || bucket.some(item => item.value === normalized)) return;
        bucket.push({ value: normalized, group });
    }

    function flattenPayloadKeys(input, prefix = '$') {
        const keys = [];
        if (!input || typeof input !== 'object') return keys;

        const walk = (value, path) => {
            if (!path) return;
            pushSuggestion(keys, path);
            if (Array.isArray(value)) {
                pushSuggestion(keys, `${path}[0]`);
                if (value[0] && typeof value[0] === 'object') {
                    Object.entries(value[0]).forEach(([childKey, childValue]) => walk(childValue, `${path}[0].${childKey}`));
                }
                return;
            }
            if (value && typeof value === 'object') {
                Object.entries(value).forEach(([childKey, childValue]) => walk(childValue, path === '$' ? `$.${childKey}` : `${path}.${childKey}`));
            }
        };

        walk(input, prefix);
        return keys;
    }

    function collectProcessVariables() {
        const suggestions = [];

        modeler.get('elementRegistry').filter(e => e.type === 'bpmn:StartEvent' || e.type === 'bpmn:Process').forEach(node => {
            const config = propertyMap[node.id] || {};
            ['variables', 'variableDefinitions'].forEach(bucketKey => {
                const mapping = config[bucketKey];
                if (mapping && typeof mapping === 'object') {
                    Object.keys(mapping).forEach(name => pushSuggestion(suggestions, name, 'Process Variables'));
                }
            });
            if (config.localVariables && typeof config.localVariables === 'object') {
                Object.keys(config.localVariables).forEach(name => pushSuggestion(suggestions, name, 'Local Variables'));
            }
        });

        return suggestions;
    }

    function collectOutputSuggestions() {
        const suggestions = [];

        modeler.get('elementRegistry').forEach(node => {
            const config = propertyMap[node.id] || {};

            ['responseMap', 'outputMapping', 'outboundMapping'].forEach(bucketKey => {
                const mapping = config[bucketKey];
                if (mapping && typeof mapping === 'object') {
                    Object.values(mapping).forEach(entry => {
                        const target = entry && typeof entry === 'object' && !Array.isArray(entry)
                            ? entry.target
                            : entry;
                        pushSuggestion(suggestions, target, 'Response Keys');
                    });
                }
            });

            if (config.resultVariable) pushSuggestion(suggestions, config.resultVariable, 'Result Variables');
        });

        ['result', 'status', 'message', 'data'].forEach(name => pushSuggestion(suggestions, name, 'Response Keys'));
        return suggestions;
    }

    function collectScopeSuggestions(scope, field, liveState) {
        const suggestions = [];
        const normalizedScope = scope || 'process';

        if (normalizedScope === 'process') {
            collectProcessVariables().forEach(item => pushSuggestion(suggestions, item.value, item.group));
        }

        if (normalizedScope === 'local') {
            const locals = liveState.localVariables;
            if (locals && typeof locals === 'object') {
                Object.keys(locals).forEach(name => pushSuggestion(suggestions, name, 'Local Variables'));
            }
        }

        if (normalizedScope === 'input') {
            ['$', '$.data', '$.payload', '$.headers', '$.query', '$.params'].forEach(path => pushSuggestion(suggestions, path, 'Payload Paths'));
            const payloadSchema = safeParseJson(liveState.payloadSchema);
            flattenPayloadKeys(payloadSchema).forEach(item => pushSuggestion(suggestions, item.value, 'Payload Paths'));
            if (field.contractRef === 'input' && field.contractSource && liveState[field.contractSource]) {
                const contract = assetContractCache[liveState[field.contractSource]];
                if (contract) contract.inputs.forEach(name => pushSuggestion(suggestions, name, 'Contract Inputs'));
            }
        }

        if (normalizedScope === 'output') {
            collectOutputSuggestions().forEach(item => pushSuggestion(suggestions, item.value, item.group));
            ['$.data', '$.status', '$.body'].forEach(name => pushSuggestion(suggestions, name, 'Response Paths'));
            if (field.contractRef === 'output' && field.contractSource && liveState[field.contractSource]) {
                const contract = assetContractCache[liveState[field.contractSource]];
                if (contract) contract.outputs.forEach(name => pushSuggestion(suggestions, name, 'Contract Outputs'));
            }
        }

        if (normalizedScope === 'task') {
            ['assignee', 'owner', 'comment', 'decision', 'formData'].forEach(name => pushSuggestion(suggestions, name, 'Task Fields'));
        }

        return suggestions;
    }

    function discoverMappingSuggestions(f, liveState) {
        const sourceScope = f.mapping?.sourceScope || 'source';
        const targetScope = f.mapping?.targetScope || 'target';

        if (f.contractSource && liveState[f.contractSource] && !assetContractCache[liveState[f.contractSource]]) {
            fetchAssetContract(liveState[f.contractSource]);
        }

        return {
            source: collectScopeSuggestions(sourceScope, f, liveState),
            target: collectScopeSuggestions(targetScope, f, liveState)
        };
    }

    function discoverSuggestions(f, liveState) {
        const suggestions = [];
        if (f.variableRef) {
            collectProcessVariables().forEach(v => {
                [v.value, `\${variables.${v.value}}`].forEach(candidate => {
                    pushSuggestion(suggestions, candidate, v.group === 'Local Variables' ? 'Local Variables' : 'Process Variables');
                });
            });
            const localVars = liveState.localVariables && typeof liveState.localVariables === 'object'
                ? Object.keys(liveState.localVariables)
                : [];
            localVars.forEach(v => {
                pushSuggestion(suggestions, `\${local.${v}}`, 'Local Variables');
            });
        }
        if (f.flowRef) projectAssets.forEach(a => pushSuggestion(suggestions, a, 'Process Assets'));
        if (f.contractRef && f.contractSource && liveState[f.contractSource]) {
            const contract = assetContractCache[liveState[f.contractSource]];
            if (contract) (f.contractRef === 'input' ? contract.inputs : contract.outputs).forEach(k => pushSuggestion(suggestions, k, f.contractRef === 'input' ? 'Contract Inputs' : 'Contract Outputs'));
            else fetchAssetContract(liveState[f.contractSource]);
        }
        return suggestions;
    }

    async function fetchAssetContract(name) {
        try {
            const data = await (await fetch(`/api/assets/contract/${encodeURIComponent(name)}`)).json();
            if (data.success) { assetContractCache[name] = data; refreshPropertyModal(); }
        } catch(e) {}
    }

    function saveAndClose(id) {
        const bo = selectedElement.businessObject;
        const pkgId = bo.nodeId || bo.$type;
        const pkg = nodeRegistry[pkgId];
        const config = collectFieldValues(bo, pkg);
        const issues = validateConfig(pkg, config);
        if (issues.length > 0) {
            openPropertyModal(config);
            return;
        }
        propertyMap[id] = enrichConfig(pkg, config);
        ZeroModal.close();
        modeler.get('canvas').addMarker(id, 'configured');
    }

    function syncNameFromModal(val) { modeler.get('modeling').updateProperties(selectedElement, { name: val }); }

    const ZeroLoader = {
        show: (msg) => { document.getElementById('loader-msg').innerText = msg; document.getElementById('zero-loader').style.display = 'flex'; },
        hide: () => document.getElementById('zero-loader').style.display = 'none'
    };

    async function persistProcess(isDeploy = false) {
        ZeroLoader.show(isDeploy ? 'Releasing to Production Tier...' : 'Synchronizing Draft...');
        try {
            const validationIssues = [];
            modeler.get('elementRegistry').filter(e => !e.labelTarget).forEach(element => {
                const bo = element.businessObject;
                const pkgId = bo.nodeId || element.type;
                const pkg = nodeRegistry[pkgId] || nodeRegistry[element.type];
                if (!pkg) return;
                const config = enrichConfig(pkg, propertyMap[bo.id] || {});
                const issues = validateConfig(pkg, config);
                if (issues.length > 0) {
                    validationIssues.push(...issues.map(issue => `${bo.id}: ${issue.message}`));
                }
                propertyMap[bo.id] = config;
            });

            if (validationIssues.length > 0) {
                ZeroLoader.hide();
                alert(`Validation failed:\n\n${validationIssues.join('\n')}`);
                return;
            }

            const { xml } = await modeler.saveXML({ format: true });
            const response = await fetch('/api/deploy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: intent.name, projectName, xml, json: propertyMap, version: intent.version })
            });
            const payload = await response.json();
            if (!response.ok) throw new Error(payload.error || 'Deployment failed');
            ZeroLoader.hide();
            if (payload.assetId) {
                const nextUrl = `/projects/${encodeURIComponent(projectName)}/modeler?assetId=${encodeURIComponent(payload.assetId)}`;
                location.href = nextUrl;
            } else {
                location.reload();
            }
        } catch (e) { ZeroLoader.hide(); alert('Error: ' + e.message); }
    }

    init();
</script>
