<div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px;">
    <div>
        <h1 style="font-size: 28px; margin: 0 0 8px 0; font-weight: 800; letter-spacing: -1px;">Governance Matrix</h1>
        <p style="color: var(--text-dim); margin: 0; font-size: 14px;">Define granular system capabilities for roles within organizational orchestration units.</p>
    </div>
    <button onclick="saveMatrix()" class="action-btn" style="background: var(--success); box-shadow: 0 4px 20px rgba(34, 197, 94, 0.2);">
        <i class="fas fa-save"></i> Save Global Matrix
    </button>
</div>

<div class="glass-card" style="padding: 0; overflow: hidden;">
    <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; min-width: 800px;">
            <thead>
                <tr style="background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--border);">
                    <th style="padding: 16px; text-align: left; width: 250px;">Organizational Unit & Role</th>
                    <% controls.forEach(control => { %>
                        <th style="padding: 16px; text-align: center;">
                            <div style="font-size: 10px; font-weight: 800; color: var(--accent); white-space: nowrap;"><%= control.permission_key %></div>
                            <div title="<%= control.description %>" style="font-size: 9px; color: var(--text-dim); font-weight: 400; cursor: help;"><%= control.category %></div>
                        </th>
                    <% }); %>
                </tr>
            </thead>
            <tbody>
                <% rows.forEach(row => { %>
                    <tr style="border-bottom: 1px solid var(--border); transition: background 0.1s;" onmouseover="this.style.background='rgba(255,255,255,0.01)'" onmouseout="this.style.background='transparent'">
                        <td style="padding: 16px;">
                            <div style="font-weight: 600; font-size: 13px;"><%= row.group_name %></div>
                            <div style="font-size: 11px; color: var(--accent); font-weight: 800; text-transform: uppercase;"><%= row.role_name %></div>
                        </td>
                        <% controls.forEach(control => { %>
                            <td style="padding: 16px; text-align: center;">
                                <label class="toggle-switch">
                                    <input type="checkbox" 
                                           data-group="<%= row.group_name %>" 
                                           data-role="<%= row.role_name %>" 
                                           data-key="<%= control.permission_key %>"
                                           <%= matrix.find(m => m.group_name === row.group_name && m.role_name === row.role_name && m.permission_key === control.permission_key && m.is_enabled) ? 'checked' : '' %>>
                                    <span class="slider"></span>
                                </label>
                            </td>
                        <% }); %>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<style>
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 34px;
        height: 18px;
    }
    .toggle-switch input { opacity: 0; width: 0; height: 0; }
    .slider {
        position: absolute;
        cursor: pointer;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: var(--sidebar-bg);
        transition: .4s;
        border-radius: 34px;
        border: 1px solid var(--border);
    }
    .slider:before {
        position: absolute;
        content: "";
        height: 12px; width: 12px;
        left: 3px; bottom: 2px;
        background-color: white;
        transition: .4s;
        border-radius: 50%;
    }
    input:checked + .slider { background-color: var(--primary); border-color: var(--primary); }
    input:checked + .slider:before { transform: translateX(16px); }
</style>

<script>
    async function saveMatrix() {
        const toggles = document.querySelectorAll('input[type="checkbox"]');
        const updates = Array.from(toggles).map(t => ({
            group: t.dataset.group,
            role: t.dataset.role,
            key: t.dataset.key,
            state: t.checked
        }));

        const res = await fetch('/api/permissions/matrix', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ updates })
        });

        if (res.ok) {
            alert('SUCCESS: Dynamic Access Matrix synchronized with persistence layer.');
            location.reload();
        } else {
            alert('SYNC FAILED: Check console for trace.');
        }
    }
</script>
