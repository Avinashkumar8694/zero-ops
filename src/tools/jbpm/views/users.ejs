<div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px;">
    <div>
        <h1 style="font-size: 28px; margin: 0 0 8px 0; font-weight: 800; letter-spacing: -1px;">Governance Suite</h1>
        <p style="color: var(--text-dim); margin: 0; font-size: 14px;">Unified Identity, Organizational Structure, and Permission Matrix.</p>
    </div>
    <div style="display: flex; gap: 8px; background: rgba(255,255,255,0.05); padding: 4px; border-radius: 12px; border: 1px solid var(--border);">
        <button onclick="switchTab('registry')" id="tab-btn-registry" class="tab-btn active">Identity Registry</button>
        <button onclick="switchTab('matrix')" id="tab-btn-matrix" class="tab-btn">Operational Matrix</button>
        <button onclick="switchTab('units')" id="tab-btn-units" class="tab-btn">Organizational Units</button>
    </div>
</div>

<div id="tab-registry" class="iam-tab-content">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h3 style="margin: 0;">Identity Registry</h3>
        <button onclick="showAddUserModal()" class="action-btn" style="background: var(--primary);"><i class="fas fa-plus"></i> Add Identity</button>
    </div>
    <div class="glass-card" style="padding: 0; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
            <tr style="text-align: left; color: var(--text-dim); background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--border);">
                <th style="padding: 16px 24px;">Identity</th>
                <th>Global Role</th>
                <th>Groups</th>
                <th style="text-align: right; padding-right: 24px;">Actions</th>
            </tr>
            <% users.forEach(u => { %>
                <tr style="border-bottom: 1px solid var(--border);">
                    <td style="padding: 16px 24px;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <div style="width: 32px; height: 32px; background: var(--accent); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 10px;">
                                <%= u.username.substring(0,2).toUpperCase() %>
                            </div>
                            <div>
                                <div style="font-weight: 700; color: white;"><%= u.full_name %></div>
                                <div style="font-size: 11px; color: var(--text-dim);">@<%= u.username %></div>
                            </div>
                        </div>
                    </td>
                    <td><span class="status-badge" style="background: rgba(56, 189, 248, 0.1); color: var(--accent);"><%= u.role.toUpperCase() %></span></td>
                    <td style="color: var(--text-dim);"><%= u.groups && u.groups[0] ? u.groups.join(', ') : 'No Assignment' %></td>
                    <td style="text-align: right; padding-right: 24px;">
                        <button onclick="showGroupModal('<%= u.username %>')" class="action-btn" style="padding: 6px 12px; font-size: 11px; background: rgba(255,255,255,0.05);">
                            <i class="fas fa-user-tag"></i> Manage Groups
                        </button>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>
</div>

<div id="tab-matrix" class="iam-tab-content" style="display: none;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <h3 style="margin: 0;">Operational Matrix</h3>
            <p style="font-size: 12px; color: var(--text-dim); margin: 4px 0 0 0;">Bind capabilities to specific (Group x Role) intersections.</p>
        </div>
        <button onclick="saveMatrix()" class="action-btn" style="background: var(--success);"><i class="fas fa-save"></i> Commit Changes</button>
    </div>
    <div class="glass-card" style="overflow-x: auto; padding: 0;">
        <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
            <thead>
                <tr style="background: rgba(255,255,255,0.03); border-bottom: 1px solid var(--border);">
                    <th style="padding: 16px 24px; text-align: left; width: 180px;">Organizational Unit (Role)</th>
                    <% controls.forEach(control => { %>
                        <th style="padding: 12px; text-align: center; writing-mode: vertical-lr; transform: rotate(180deg); opacity: 0.8; font-weight: 900;">
                            <%= control.permission_key.replace('_', ' ') %>
                        </th>
                    <% }) %>
                </tr>
            </thead>
            <tbody>
                <% rows.forEach(row => { %>
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 12px 24px; border-right: 1px solid var(--border);">
                            <div style="font-weight: 700; color: white;"><%= row.group_name %></div>
                            <div style="font-size: 10px; color: var(--accent);"><%= row.role_name.toUpperCase() %></div>
                        </td>
                        <% controls.forEach(control => { 
                            const isEnabled = matrix.some(m => m.group_name === row.group_name && m.role_name === row.role_name && m.permission_key === control.permission_key && m.is_enabled);
                        %>
                            <td style="padding: 8px; text-align: center; background: <%= isEnabled ? 'rgba(34, 197, 94, 0.03)' : 'transparent' %>">
                                <label class="matrix-toggle">
                                    <input type="checkbox" data-group="<%= row.group_name %>" data-role="<%= row.role_name %>" data-key="<%= control.permission_key %>" <%= isEnabled ? 'checked' : '' %>>
                                    <span class="matrix-slider"></span>
                                </label>
                            </td>
                        <% }) %>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<div id="tab-units" class="iam-tab-content" style="display: none;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h3 style="margin: 0;">Organizational Units</h3>
        <button onclick="showAddGroupModal()" class="action-btn" style="background: var(--primary);"><i class="fas fa-plus"></i> Create New Unit</button>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
        <% groups.forEach(g => { %>
            <div class="glass-card" style="padding: 24px; border-top: 2px solid var(--accent);">
                <div style="font-weight: 800; font-size: 16px; margin-bottom: 8px; color: white;"><%= g.group_name %></div>
                <p style="color: var(--text-dim); font-size: 13px; margin: 0; min-height: 40px;"><%= g.description || 'System-defined business unit.' %></p>
                <div style="margin-top: 20px; border-top: 1px solid var(--border); padding-top: 16px; display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 10px; color: var(--text-dim);">ID: <%= g.id %></span>
                    <i class="fas fa-shield-alt" style="color: var(--accent); opacity: 0.5;"></i>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<style>
    .tab-btn { background: transparent; border: none; color: var(--text-dim); padding: 8px 16px; border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer; transition: all 0.2s; }
    .tab-btn.active { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3); }
    
    .matrix-toggle { position: relative; display: inline-block; width: 34px; height: 16px; }
    .matrix-toggle input { opacity: 0; width: 0; height: 0; }
    .matrix-slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(255,255,255,0.1); transition: .4s; border-radius: 16px; border: 1px solid var(--border); }
    .matrix-slider:before { position: absolute; content: ""; height: 10px; width: 10px; left: 2px; bottom: 2px; background-color: var(--text-dim); transition: .4s; border-radius: 50%; }
    input:checked + .matrix-slider { background-color: var(--success); }
    input:checked + .matrix-slider:before { transform: translateX(18px); background-color: white; }
</style>

<script>
    function switchTab(name) {
        document.querySelectorAll('.iam-tab-content').forEach(t => t.style.display = 'none');
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + name).style.display = 'block';
        document.getElementById('tab-btn-' + name).classList.add('active');
    }

    async function saveMatrix() {
        const updates = [];
        document.querySelectorAll('.matrix-toggle input').forEach(cb => {
            updates.push({
                group: cb.dataset.group,
                role: cb.dataset.role,
                key: cb.dataset.key,
                state: cb.checked
            });
        });

        const res = await fetch('/api/permissions/matrix', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ updates })
        });
        if (res.ok) alert('Governance Matrix Synchronized Successfully.');
        else alert('Matrix update failed.');
    }

    // Modal orchestration logic... (showAddUserModal, showGroupModal, etc.)
</script>
