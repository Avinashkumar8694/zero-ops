{
  "name": "zero-ops",
  "version": "1.1.6",
  "description": "CLI utility for managing named paths (bigbang flow)",
  "main": "zero-ops.js",
  "bin": {
    "zero-ops": "zero-ops.js"
  },
  "type": "module",
  "scripts": {
    "build": "echo 'No build step required for this JS-only CLI'",
    "build:jbpm": "tsc -p tsconfig.json",
    "dev:jbpm": "tsx watch src/tools/jbpm/index.ts",
    "install:global": "npm install -g .",
    "package": "npm pack",
    "release": "npm publish",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avinashkumar8694/zero-ops.git"
  },
  "keywords": [
    "cli",
    "path-management",
    "zero-ops",
    "bigbang",
    "automation"
  ],
  "author": "Avinash Kumar Gupta",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/avinashkumar8694/zero-ops/issues"
  },
  "homepage": "https://github.com/avinashkumar8694/zero-ops#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "zero-ops.js",
    "src",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "dependencies": {
    "ajv": "^8.12.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bpmn-js": "^18.14.0",
    "commander": "^12.0.0",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.0",
    "jsonpath": "^1.1.1",
    "pg": "^8.20.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
